FROM ubuntu:22.04

# 安装依赖（包括 perf）
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    pkg-config \
    libgrpc++-dev \
    libprotobuf-dev \
    protobuf-compiler \
    protobuf-compiler-grpc \
    libcurl4-openssl-dev \
    linux-tools-common \
    linux-tools-6.8.0-124-generic \
    linux-cloud-tools-6.8.0-124-generic \
    bpftrace \
    perl \
    python3 \
    python3-pip \
    git \
    && rm -rf /var/lib/apt/lists/*

# 创建 perf 软链接（如果 perf 被安装到其他位置）
RUN ln -sf /usr/lib/linux-tools/6.8.0-124-generic/perf /usr/bin/perf 2>/dev/null || true

# 安装 Python 依赖
RUN pip3 install minio py-spy

# 安装 FlameGraph
RUN cd /opt && \
    git clone https://gitee.com/mirrors/FlameGraph.git

# 设置工作目录
WORKDIR /app

# 复制源代码
COPY . .

# 编译
RUN mkdir -p build && cd build && \
    cmake .. && \
    make -j$(nproc)

# 设置环境变量
ENV PATH="/opt/FlameGraph:${PATH}"
ENV PYTHONPATH="/app"

# 启动 agent
CMD ["./build/drop_agent"]
